<mvc:View
    controllerName="bookshop.controller.UserView"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns:shellfooter="sap.ushell.ui.footerbar"
    xmlns="sap.m"
>
    <Page
        showNavButton="false"
        id="UserView"
    >
        <content>
            <Button
                press="onLogOff"
                icon="sap-icon://log"
                class="sapUiTinyMargin"
            />
            <Table
            mode="MultiSelect"
            selectionChange="onSelectionChangeLibro"
                id="tableUser"
                growing="true"
                items="{
        path: '/Libri',
        parameters: {
            $select: 'ID,titolo,descrizione,genere,stock,prezzo,autore_ID',
            $expand: {
                autore: {
                    $select: 'ID,nome'
                }
            }
        }
    }"
            >
                <columns>
                    <Column>
                        <Text text="titolo" />
                    </Column>
                    <Column>
                        <Text text="Descrizione" />
                    </Column>
                    <Column>
                        <Text text="Autore" />
                    </Column>
                    <Column>
                        <Text text="Genere" />
                    </Column>
                    <Column>
                        <Text text="Quantità" />
                    </Column>
                    <Column>
                        <Text text="Prezzo" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem >
                        <cells>
                            <Text text="{titolo}" />
                            <Text text="{descrizione}" />
                            <Text text="{autore/nome}" />
                            <Text text="{genere}" />
                            <Text id="stockText" text="{stock} disponibili" />
                            <Text text="{prezzo}€" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    class="sapUiTinyMarginBegin"
                    icon="sap-icon://cart"
                    id="acquistaLibroBtn"
                    text="Acquista"
                    type="Emphasized"
                    press="AcquistaLibro"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
